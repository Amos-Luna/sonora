APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
API_HOST_PORT=8001
API_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=postgresql+psycopg://sonora:sonora@postgres:5432/sonora
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-in-production
JWT_ISSUER=sonora
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_PREVIEW_PER_MINUTE=12
MAX_MEDIA_DURATION_SECONDS=1800
PUBLIC_BASE_URL=http://localhost:8001
FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Single-owner account (single-user mode). Only this email can log in.
# Guests receive access through invite links generated by the owner.
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-a-very-strong-password
OWNER_FULL_NAME=Owner

# Invite settings
INVITE_DEFAULT_TTL_HOURS=24
INVITE_MAX_TTL_HOURS=336
INVITE_DEFAULT_MAX_USES=1
INVITE_REDEEM_PER_MINUTE=20

STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data/media
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
